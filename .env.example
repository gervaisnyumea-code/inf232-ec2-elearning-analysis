# .env.example - example values for INF232 app
# Copy to .env and fill sensitive values before running.
SECRET_KEY=change-me
STREAMLIT_SERVER_PORT=8501
MODEL_DIR=data/models
ENABLE_MODEL_ORCHESTRATION=false
MODEL_LIST=classifier_model.pkl,regression_model.pkl
DATA_STREAM_ENABLED=false
DATA_STREAM_SOURCE=simulated
EXPORT_DIR=reports
LOG_LEVEL=INFO
# Example model placeholders:
# MODEL_NN_1_PATH=data/models/brain_net_1.pkl
# MODEL_NN_2_PATH=data/models/brain_net_2.pkl
# LLM API keys placeholders (example values). Copy these into .env before running.
# GEMINI_API_KEY_1=your_gemini_key_1
# GEMINI_API_KEY_2=your_gemini_key_2
# MISTRAL_API_KEY_1=your_mistral_key_1
# MISTRAL_API_KEY_2=your_mistral_key_2
# GROQ_API_KEY_1=your_groq_key_1
# GROQ_API_KEY_2=your_groq_key_2
# LLM_USAGE:
#  - MISTRAL: summarization of periodic reports and anomaly extraction
#  - GEMINI: narrative report generation and user-facing recommendations
#  - GROQ: reasoning, reconciliation and ensemble-level meta-analysis
# LLM control / quotas (disable real calls by default in example):
# LLM_CALLS_ENABLED=false
# LLM_MAX_CALLS_PER_HOUR=60
# LLM_PERIODIC_INTERVAL_SEC=3600
# Optional: set provider API URLs if required by your provider
# MISTRAL_API_URL=https://api.mistral.ai/v1/models/...
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta2/models/...
# GROQ_API_URL=https://api.groq.ai/v1/...
# Example additional model placeholders:
# MODEL_NN_1_PATH=data/models/nn_model_1.pkl
# MODEL_NN_2_PATH=data/models/nn_model_2.pkl
